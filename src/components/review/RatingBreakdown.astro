---
import {
  ratingLabels,
  ratingWeights,
  type RatingDimension,
  type RatingScores,
} from '../../utils/rating';
interface Props {
  rating: RatingScores & { overall: number };
}
const { rating } = Astro.props;
const dimensions = Object.keys(ratingWeights) as RatingDimension[];
---

<section class="ratings">
  <div>
    <span class="section-kicker">Score card</span><h2>Seven checks. One weighted score.</h2><p>
      Output matters most. Support matters too, just less. That is the math—not a gut-feel average.
    </p>
  </div><div class="bars">
    {
      dimensions.map((dimension) => (
        <div class="bar">
          <>
            <div>
              <>
                <span>
                  {ratingLabels[dimension]}{' '}
                  <small>{Math.round(ratingWeights[dimension] * 100)}%</small>
                </span>
                <strong>{rating[dimension].toFixed(1)}</strong>
              </>
            </div>
            <meter
              min="0"
              max="10"
              value={rating[dimension]}
              aria-label={`${ratingLabels[dimension]} ${rating[dimension]} out of 10`}
            >
              {rating[dimension]}
            </meter>
          </>
        </div>
      ))
    }
  </div>
</section>
<style>
  .ratings {
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: clamp(2rem, 5vw, 5rem);
    padding-block: 3rem;
  }
  h2 {
    margin: 0.5rem 0;
    font-family: 'Newsreader Variable', serif;
    font-size: 2.4rem;
    line-height: 1;
  }
  p {
    color: var(--muted);
    font-size: 0.88rem;
  }
  .bar + .bar {
    margin-top: 0.9rem;
  }
  .bar > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.8rem;
  }
  .bar small {
    color: var(--muted);
  }
  .bar strong {
    font-size: 0.82rem;
  }
  meter {
    width: 100%;
    height: 0.7rem;
    border: 1px solid var(--ink);
    border-radius: 0;
    background: transparent;
  }
  meter::-webkit-meter-bar {
    background: var(--paper-deep);
  }
  meter::-webkit-meter-optimum-value {
    background: var(--signal);
  }
  meter::-moz-meter-bar {
    background: var(--signal);
  }
  @media (max-width: 720px) {
    .ratings {
      grid-template-columns: 1fr;
    }
  }
</style>
