---
import { Icon } from 'astro-icon/components';
interface Props {
  pros: string[];
  cons: string[];
}
---

<section class="pros-cons">
  <div class="pros">
    <h2><Icon name="lucide:plus" size={23} /> What works</h2><ul>
      {Astro.props.pros.map((item) => <li>{item}</li>)}
    </ul>
  </div><div class="cons">
    <h2><Icon name="lucide:minus" size={23} /> What trips</h2><ul>
      {Astro.props.cons.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</section>
<style>
  .pros-cons {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    overflow: clip;
  }
  .pros-cons > div {
    padding: 1.4rem;
  }
  .pros {
    background: rgba(201, 255, 69, 0.24);
    border-right: 1px solid var(--ink);
  }
  .cons {
    background: rgba(255, 90, 54, 0.1);
  }
  h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-family: 'Newsreader Variable', serif;
    font-size: 2rem;
  }
  ul {
    margin: 0.8rem 0 0;
    padding-left: 1.2rem;
  }
  li + li {
    margin-top: 0.55rem;
  }
  @media (max-width: 650px) {
    .pros-cons {
      grid-template-columns: 1fr;
    }
    .pros {
      border-right: 0;
      border-bottom: 1px solid var(--ink);
    }
  }
</style>
