---
import { Icon } from 'astro-icon/components';
interface Props {
  title?: string;
  message?: string;
}
const { title = 'Nothing here yet', message = 'We checked twice. This shelf is still empty.' } =
  Astro.props;
---

<div class="empty">
  <Icon name="lucide:package-open" size={31} /><h2>{title}</h2><p>{message}</p>
</div>
<style>
  .empty {
    border: 1px dashed var(--ink);
    border-radius: var(--radius);
    padding: 3rem 1.5rem;
    background: rgba(255, 255, 255, 0.26);
  }
  h2 {
    margin: 0.7rem 0 0.2rem;
    font-family: 'Newsreader Variable', serif;
    font-size: 2rem;
  }
  p {
    margin: 0;
    color: var(--muted);
  }
</style>
