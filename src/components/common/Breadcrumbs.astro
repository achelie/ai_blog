---
import { Icon } from 'astro-icon/components';
import { breadcrumbJsonLd } from '../../utils/seo';

interface Props {
  items: Array<{ name: string; url: string }>;
}
const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb" data-pagefind-ignore>
  <ol>
    {
      items.map((item, index) => (
        <li>
          <a href={item.url}>{item.name}</a>
          {index < items.length - 1 && <Icon name="lucide:chevron-right" size={14} />}
        </li>
      ))
    }
  </ol>
</nav>
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd(items))} />

<style>
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 1.25rem 0;
  }
  .breadcrumbs li {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.76rem;
    color: var(--muted);
  }
  .breadcrumbs li:last-child a {
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
  }
</style>
