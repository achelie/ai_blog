---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleCard from '../common/ArticleCard.astro';
import {
  articleUrl,
  isPublished,
  selectRelatedArticles,
  type ArticleCollection,
} from '../../utils/content';

type ArticleEntry =
  | CollectionEntry<'reviews'>
  | CollectionEntry<'comparisons'>
  | CollectionEntry<'alternatives'>
  | CollectionEntry<'best'>
  | CollectionEntry<'guides'>;

interface Props {
  current: {
    collection: ArticleCollection;
    slug: string;
    category: string;
    relatedArticles?: string[];
  };
}

const { current } = Astro.props;
const collections = await Promise.all([
  getCollection('reviews', isPublished),
  getCollection('comparisons', isPublished),
  getCollection('alternatives', isPublished),
  getCollection('best', isPublished),
  getCollection('guides', isPublished),
]);
const entries = collections.flat() as ArticleEntry[];
const currentKey = `${current.collection}/${current.slug}`;
const candidates = entries.map((entry) => ({
  key: `${entry.collection}/${entry.data.slug}`,
  category: entry.data.category,
  publishedAt: entry.data.publishedAt,
  entry,
}));
const selected = selectRelatedArticles(
  candidates,
  currentKey,
  current.category,
  current.relatedArticles,
).map((candidate) => candidate.entry);

const items = selected.map((entry) => ({
  title: entry.data.title,
  description: entry.data.description,
  href: articleUrl(entry.collection, entry.data.slug),
  type:
    entry.collection === 'best'
      ? 'Best list'
      : `${entry.collection.charAt(0).toUpperCase()}${entry.collection.slice(1, -1)}`,
  category: entry.data.category,
  date: entry.data.publishedAt,
  image: entry.data.featuredImage,
  imageAlt: entry.data.featuredImageAlt,
}));
const accents = ['lime', 'signal', 'sky'] as const;
---

{
  items.length > 0 && (
    <section class="related" aria-labelledby="related-title">
      <div class="related-head">
        <div>
          <span class="section-kicker">Continue the research</span>
          <h2 id="related-title">Read related articles</h2>
        </div>
        <p>More independent comparisons, buying guides, and field notes from evidique.</p>
      </div>
      <div class="related-grid">
        {items.map((item, index) => (
          <div class="related-item">
            <ArticleCard {...item} accent={accents[index]} />
          </div>
        ))}
      </div>
    </section>
  )
}

<style>
  .related {
    margin-top: clamp(4rem, 9vw, 7rem);
    border-top: 1px solid var(--ink);
    padding-top: clamp(1.5rem, 3vw, 2.25rem);
  }
  .related-head {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(16rem, 0.65fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: end;
    padding-bottom: clamp(2rem, 5vw, 4.5rem);
  }
  .related-head h2 {
    max-width: 12ch;
    margin: 0.35rem 0 0;
    font-family: 'Newsreader Variable', serif;
    font-size: clamp(2.75rem, 6vw, 5.25rem);
    font-weight: 540;
    line-height: 0.9;
    letter-spacing: -0.05em;
  }
  .related-head p {
    max-width: 31rem;
    margin: 0 0 0.35rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .related-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(0, 0.88fr) minmax(0, 0.94fr);
    gap: 1rem;
    align-items: stretch;
  }
  .related-item {
    min-width: 0;
  }
  @media (max-width: 980px) {
    .related-head {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .related-grid {
      grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    }
    .related-item:last-child {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 680px) {
    .related-head {
      padding-bottom: 2rem;
    }
    .related-head h2 {
      font-size: clamp(2.6rem, 13vw, 4rem);
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
    .related-item:last-child {
      grid-column: auto;
    }
  }
</style>
