---
import { Icon } from 'astro-icon/components';
---

<aside class="disclosure" data-pagefind-ignore>
  <Icon name="lucide:handshake" size={22} /><p>
    <strong>Money note:</strong> This page may use affiliate links. They never change our ranking method
    or the price you pay. Demonstration links are disabled.
  </p>
</aside>
<style>
  .disclosure {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    border: 1px solid var(--ink);
    border-radius: 0.8rem;
    background: rgba(201, 255, 69, 0.22);
    padding: 1rem;
  }
  p {
    margin: 0;
    font-size: 0.84rem;
  }
</style>
