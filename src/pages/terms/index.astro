const sections = [
  { depth: 2, slug: 'accepting-these-terms', text: 'Accepting these terms' },
  { depth: 2, slug: 'who-may-use-the-site', text: 'Who may use the site' },
  { depth: 2, slug: 'editorial-information-not-advice', text: 'Editorial information, not advice' },
  {
    depth: 2,
    slug: 'accuracy-pricing-and-product-changes',
    text: 'Accuracy, pricing, and product changes',
  },
  {
    depth: 2,
    slug: 'third-party-products-and-purchases',
    text: 'Third-party products and purchases',
  },
  { depth: 2, slug: 'affiliate-links', text: 'Affiliate links' },
  { depth: 2, slug: 'intellectual-property', text: 'Intellectual property' },
  { depth: 2, slug: 'acceptable-use', text: 'Acceptable use' },
  { depth: 2, slug: 'availability-and-changes', text: 'Availability and changes' },
