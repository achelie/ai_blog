---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AlternativesList from '../../components/comparison/AlternativesList.astro';
import SoftwareCard from '../../components/common/SoftwareCard.astro';
import { isPublished } from '../../utils/content';
import { absoluteUrl } from '../../utils/seo';
export async function getStaticPaths() {
  const entries = await getCollection('alternatives', isPublished);
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}
interface Props {
  entry: CollectionEntry<'alternatives'>;
}
const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const [software, authors, reviews] = await Promise.all([
  getCollection('software'),
  getCollection('authors'),
  getCollection('reviews', isPublished),
]);
const primary = software.find((item) => item.data.slug === entry.data.primarySoftware);
const author = authors.find((item) => item.data.slug === entry.data.author);
if (!primary || !author) throw new Error('Missing alternatives relationship');
const items = entry.data.alternatives.map((candidate) => {
  const product = software.find((item) => item.data.slug === candidate.software);
  if (!product) throw new Error(`Missing software ${candidate.software}`);
  const review = reviews.find((item) => item.data.software === candidate.software);
  return {
    name: product.data.name,
    bestFor: candidate.bestFor,
    advantage: candidate.advantage,
    drawback: candidate.drawback,
    price:
      product.data.startingPrice === null
        ? 'Verify current price with vendor'
        : `${product.data.currency} ${product.data.startingPrice}`,
    reviewUrl: review ? `/reviews/${review.data.slug}/` : undefined,
  };
});
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishedAt.toISOString(),
  dateModified: entry.data.updatedAt.toISOString(),
  author: { '@type': 'Person', name: author.data.name },
  mainEntityOfPage: absoluteUrl(`/alternatives/${entry.data.slug}/`),
  creativeWorkStatus: entry.data.demonstration ? 'Demonstration content' : 'Published',
};
---

<ArticleLayout
  entry={entry}
  type="Alternatives"
  section="Alternatives"
  headings={headings}
  author={author}
  jsonLd={jsonLd}
>
  <h2>The product being replaced</h2><SoftwareCard {...primary.data} />
  <Content />
  <h2>Alternative shortlist</h2><AlternativesList items={items} />
</ArticleLayout>
