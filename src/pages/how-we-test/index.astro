---
import { getCollection, render } from 'astro:content';
import PolicyPageLayout from '../../layouts/PolicyPageLayout.astro';
import { absoluteUrl } from '../../utils/seo';
const guides = await getCollection('guides');
const entry = guides.find((item) => item.data.slug === 'how-we-test-ai-software');
const authors = await getCollection('authors');
if (!entry) throw new Error('Missing testing guide');
const author = authors.find((item) => item.data.slug === entry.data.author);
if (!author) throw new Error('Missing author');
const { Content, headings } = await render(entry);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishedAt.toISOString(),
  dateModified: entry.data.updatedAt.toISOString(),
  author: { '@type': 'Person', name: author.data.name },
  mainEntityOfPage: absoluteUrl('/how-we-test/'),
};
---

<PolicyPageLayout
  title={entry.data.title}
  description={entry.data.description}
  seoTitle={entry.data.seo.title}
  seoDescription={entry.data.seo.description}
  canonical={entry.data.seo.canonical}
  kicker="Independent testing method"
  recordLabel="Method record"
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  highlights={[
    'We define the task and success checks before opening the product.',
    'Seven weighted dimensions turn evidence into a comparable score.',
    'A named editor owns every claim, update, correction, and verdict.',
  ]}
  sections={headings}
  type="article"
  {jsonLd}
  author={author.data}
>
  <Content />
</PolicyPageLayout>
