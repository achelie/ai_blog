---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/common/Breadcrumbs.astro';
import ArticleHero from '../components/article/ArticleHero.astro';
import DemonstrationNotice from '../components/article/DemonstrationNotice.astro';
import TableOfContents from '../components/article/TableOfContents.astro';
import AuthorBox from '../components/article/AuthorBox.astro';
import RelatedArticles from '../components/article/RelatedArticles.astro';
import type { ArticleCollection } from '../utils/content';

interface Props {
  entry: {
    collection: ArticleCollection;
    data: {
      title: string;
      description: string;
      slug: string;
      category: string;
      author: string;
      publishedAt: Date;
      updatedAt: Date;
      featuredImage: string;
      featuredImageAlt?: string;
      relatedArticles?: string[];
      demonstration: boolean;
      seo: { title: string; description: string; canonical?: string; noindex: boolean };
    };
  };
  type: string;
  section: string;
  headings: Array<{ depth: number; slug: string; text: string }>;
  author: { data: { name: string; slug: string; bio: string; role: string; avatar: string } };
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  sectionUrl?: string;
  currentUrl?: string;
}
const {
  entry,
  type,
  section,
  headings,
  author,
  jsonLd,
  sectionUrl = `/${section.toLowerCase()}/`,
  currentUrl = `/${section.toLowerCase()}/${entry.data.slug}/`,
} = Astro.props;
const { data } = entry;
---

<BaseLayout
  title={data.seo.title}
  description={data.seo.description}
  canonical={data.seo.canonical}
  image={data.featuredImage}
  type="article"
  noindex={data.seo.noindex}
  publishedAt={data.publishedAt}
  updatedAt={data.updatedAt}
  jsonLd={jsonLd}
>
  <div class="shell">
    <Breadcrumbs
      items={[
        { name: 'Home', url: '/' },
        { name: section, url: sectionUrl },
        { name: data.title, url: currentUrl },
      ]}
    /><ArticleHero
      type={type}
      category={data.category}
      title={data.title}
      description={data.description}
      publishedAt={data.publishedAt}
      updatedAt={data.updatedAt}
    />
    {
      data.featuredImageAlt && (
        <figure class="featured-image">
          <img
            src={data.featuredImage}
            alt={data.featuredImageAlt}
            width="1200"
            height="630"
            fetchpriority="high"
          />
        </figure>
      )
    }
    {data.demonstration && <DemonstrationNotice />}
  </div>
  <div class="shell article-grid">
    <aside><TableOfContents headings={headings} /></aside>
    <article class="prose"><slot /></article>
  </div>
  <div class="shell after-article">
    <AuthorBox {...author.data} />
    <RelatedArticles
      current={{
        collection: entry.collection,
        slug: data.slug,
        category: data.category,
        relatedArticles: data.relatedArticles,
      }}
    />
  </div>
</BaseLayout>
<style>
  .article-grid {
    display: grid;
    grid-template-columns: 15rem minmax(0, 44rem);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
    padding-block: 4rem;
  }
  .featured-image {
    margin: 0 0 1rem;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--paper-deep);
    box-shadow: var(--shadow);
  }
  .featured-image img {
    display: block;
    width: 100%;
    height: auto;
  }
  .article-grid > aside {
    position: sticky;
    top: 7rem;
  }
  .after-article {
    padding-block: 4rem 6rem;
  }
  @media (max-width: 800px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
    .article-grid > aside {
      position: static;
    }
  }
</style>
