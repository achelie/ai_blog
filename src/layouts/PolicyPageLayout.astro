---
import { Icon } from 'astro-icon/components';
import AuthorBox from '../components/article/AuthorBox.astro';
import TableOfContents from '../components/article/TableOfContents.astro';
import Breadcrumbs from '../components/common/Breadcrumbs.astro';
import { site } from '../data/site';
import BaseLayout from './BaseLayout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Author {
  name: string;
  slug: string;
  bio: string;
  role: string;
  avatar: string;
}

interface Props {
  title: string;
  description: string;
  seoTitle?: string;
  seoDescription?: string;
  canonical?: string;
  kicker: string;
  recordLabel: string;
  updatedAt: Date;
  publishedAt?: Date;
  highlights: string[];
  sections: Heading[];
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  author?: Author;
}

const {
  title,
  description,
  seoTitle,
  seoDescription,
  canonical,
  kicker,
  recordLabel,
  updatedAt,
  publishedAt,
  highlights,
  sections,
  type = 'website',
  jsonLd,
  author,
} = Astro.props;

const formatDate = (date: Date) => date.toLocaleDateString('en-US', { dateStyle: 'long' });
---

<BaseLayout
  title={seoTitle ?? title}
  description={seoDescription ?? description}
  {canonical}
  type={type}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  jsonLd={jsonLd}
>
  <div class="shell">
    <Breadcrumbs
      items={[
        { name: 'Home', url: '/' },
        { name: title, url: Astro.url.pathname },
      ]}
    />

    <header class="policy-hero">
      <div class="policy-title">
        <span class="section-kicker">{kicker}</span>
        <h1>{title}</h1>
      </div>
      <div class="record-card">
        <div class="record-meta">
          <span>{recordLabel}</span>
          <span>No. {String(sections.length).padStart(2, '0')}</span>
        </div>
        <p>{description}</p>
        <div class="record-dates">
          {
            publishedAt && (
              <span>
                Published{' '}
                <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
              </span>
            )
          }
          <span>
            {publishedAt ? 'Updated' : 'Effective'}{' '}
            <time datetime={updatedAt.toISOString()}>{formatDate(updatedAt)}</time>
          </span>
        </div>
        <span class="record-stamp">Public record</span>
      </div>
    </header>

    <section class="policy-brief" aria-labelledby="brief-title">
      <div class="brief-label">
        <Icon name="lucide:file-check-2" size={20} />
        <h2 id="brief-title">At a glance</h2>
      </div>
      <ol>
        {highlights.map((highlight) => <li>{highlight}</li>)}
      </ol>
    </section>

    <div class="policy-grid">
      <aside class="policy-rail">
        <TableOfContents headings={sections} />
        <p class="rail-note">
          Spot a gap? <a href={`mailto:${site.email}`}>Tell the editor</a>. Specific URLs and
          primary sources help us fix things faster.
        </p>
      </aside>
      <article class="prose policy-copy"><slot /></article>
    </div>

    {
      author && (
        <div class="policy-author">
          <AuthorBox {...author} />
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .policy-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(17rem, 0.68fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
    padding-block: clamp(3rem, 7vw, 6.5rem) clamp(2.5rem, 5vw, 4.5rem);
  }

  .policy-title h1 {
    max-width: 11ch;
    margin: 0.9rem 0 0;
    font-family: 'Newsreader Variable', serif;
    font-size: clamp(3.5rem, 8.5vw, 7.6rem);
    font-weight: 560;
    line-height: 0.84;
    letter-spacing: -0.06em;
  }

  .record-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--ink);
    background:
      radial-gradient(circle at 82% 12%, rgba(201, 255, 69, 0.18), transparent 34%), var(--ink);
    color: var(--paper);
    padding: 1.3rem 1.35rem 1.5rem;
    box-shadow: 0.55rem 0.55rem 0 var(--lime);
  }

  .record-meta,
  .record-dates {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: rgba(244, 240, 230, 0.68);
    font-size: 0.67rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .record-card > p {
    margin: 2.4rem 0 2rem;
    font-family: 'Newsreader Variable', serif;
    font-size: 1.28rem;
    line-height: 1.35;
  }

  .record-dates {
    flex-direction: column;
    gap: 0.3rem;
    text-transform: none;
  }

  .record-stamp {
    position: absolute;
    top: 3.2rem;
    right: -1.9rem;
    border: 2px solid var(--lime);
    color: var(--lime);
    padding: 0.25rem 2rem;
    font-size: 0.62rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transform: rotate(11deg);
  }

  .policy-brief {
    display: grid;
    grid-template-columns: minmax(10rem, 0.38fr) minmax(0, 1.62fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    border-block: 1px solid var(--ink);
    padding-block: 1.5rem;
  }

  .brief-label {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    color: var(--signal);
  }

  .brief-label h2 {
    margin: 0;
    color: var(--ink);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .policy-brief ol {
    display: grid;
    grid-template-columns: 1.2fr 1fr 0.8fr;
    gap: clamp(1rem, 3vw, 2.5rem);
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: brief;
  }

  .policy-brief li {
    position: relative;
    margin: 0;
    padding-left: 1.8rem;
    font-size: 0.84rem;
    font-weight: 650;
    line-height: 1.45;
    counter-increment: brief;
  }

  .policy-brief li::before {
    position: absolute;
    left: 0;
    color: var(--signal);
    content: '0' counter(brief);
    font-family: 'Newsreader Variable', serif;
    font-size: 1rem;
    font-weight: 750;
  }

  .policy-grid {
    display: grid;
    grid-template-columns: 14rem minmax(0, 46rem);
    gap: clamp(2.5rem, 8vw, 8rem);
    align-items: start;
    padding-block: clamp(3.5rem, 7vw, 6.5rem);
  }

  .policy-rail {
    position: sticky;
    top: 7rem;
  }

  .rail-note {
    border-top: 1px solid var(--line);
    margin: 1.4rem 0 0;
    padding-top: 1rem;
    color: var(--muted);
    font-size: 0.74rem;
    line-height: 1.55;
  }

  .rail-note a {
    color: var(--ink);
    font-weight: 750;
    text-decoration-color: var(--signal);
  }

  .policy-copy {
    counter-reset: policy-section;
  }

  .policy-copy :global(h2) {
    display: grid;
    grid-template-columns: 2.4rem minmax(0, 1fr);
    gap: 0.8rem;
    align-items: baseline;
    border-top: 1px solid var(--ink);
    padding-top: 0.65rem;
    counter-increment: policy-section;
  }

  .policy-copy :global(h2)::before {
    color: var(--signal);
    content: counter(policy-section, decimal-leading-zero);
    font-family: 'Newsreader Variable', serif;
    font-size: 1rem;
    letter-spacing: 0;
  }

  .policy-copy :global(ul) {
    padding-left: 1.2rem;
  }

  .policy-copy :global(li + li) {
    margin-top: 0.55rem;
  }

  .policy-copy :global(strong) {
    font-family: 'Public Sans Variable', sans-serif;
    font-size: 0.92em;
  }

  .policy-author {
    max-width: 65rem;
    padding-block: 0 6rem;
  }

  @media (max-width: 820px) {
    .policy-hero,
    .policy-brief,
    .policy-grid {
      grid-template-columns: 1fr;
    }

    .policy-title h1 {
      max-width: 12ch;
    }

    .record-card {
      max-width: 32rem;
    }

    .policy-brief {
      gap: 1.2rem;
    }

    .policy-brief ol {
      grid-template-columns: 1fr 1fr;
    }

    .policy-rail {
      position: static;
    }
  }

  @media (max-width: 540px) {
    .policy-title h1 {
      font-size: clamp(3.2rem, 17vw, 5rem);
    }

    .record-card {
      box-shadow: 0.35rem 0.35rem 0 var(--lime);
    }

    .policy-brief ol {
      grid-template-columns: 1fr;
    }

    .policy-grid {
      padding-top: 2.5rem;
    }
  }
</style>
